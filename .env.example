# Application Settings
APP_VERSION=1.0.0
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Security (Required) — change this to any strong secret string
API_KEY=your_secure_api_key_here

# File Paths (Defaults provided — no need to change)
DUCKDB_PATH=./data/shipforesight.db
MODELS_DIR=./models

# Groq API Keys — rotates automatically when one hits rate limit
# Key 1 is required. Keys 2 and 3 are optional fallbacks.
# Get your free keys at: https://console.groq.com
GROQ_API_KEY_1=gsk_your_primary_groq_api_key_here
GROQ_API_KEY_2=gsk_your_second_groq_api_key_here
GROQ_API_KEY_3=gsk_your_third_groq_api_key_here

# Explain token TTL in seconds (300 = 5 minutes)
EXPLAIN_TTL_SECONDS=300
